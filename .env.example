# ═══════════════════════════════════════════
# 🛡️ WiFi Guard Bot — Configuration
# ═══════════════════════════════════════════
# Copy file ini ke .env dan isi konfigurasinya:
# cp .env.example .env

# ──────────────────────────────────────────
# WhatsApp Configuration
# ──────────────────────────────────────────
# Nomor/ID WhatsApp yang akan menerima alert (bisa nomor perorangan atau ID Grup)
# Contoh Nomor: 6281234567890
# Contoh Grup: 120363406334144686@g.us
ALERT_PHONE_NUMBER=6281234567890

# ──────────────────────────────────────────
# Network Scanner Configuration
# ──────────────────────────────────────────
# Interface jaringan (kosongkan untuk auto-detect)
# Contoh: wlan0, wlp2s0, eth0
NETWORK_INTERFACE=

# Interval scan dalam detik (default: 3 untuk real-time)
SCAN_INTERVAL=3

# Subnet jaringan (kosongkan untuk auto-detect)
# Contoh: 192.168.1.0/24
NETWORK_SUBNET=

# ──────────────────────────────────────────
# Alert Configuration
# ──────────────────────────────────────────
# Aktifkan alert WhatsApp (true/false)
ALERTS_ENABLED=true

# Kirim alert saat perangkat disconnect (true/false)
ALERT_ON_DISCONNECT=true

# Kirim daily report (true/false)
DAILY_REPORT_ENABLED=true

# Jam kirim daily report (format 24h, default: 08:00)
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0

# ──────────────────────────────────────────
# Voice Alert Configuration (Suara Speaker Manusia AI)
# ──────────────────────────────────────────
# Aktifkan suara peringatan via speaker (true/false)
VOICE_ALERT_ENABLED=true

# Gaya Suara: 
# - 'stasiun' (Suara Manusia Pengumuman Stasiun Kereta 🚆 - Jernih, Formal & Elegan)
# - 'human'   (Suara Manusia Indonesia Natural 🎙️)
# - 'anime'   (Suara Imut Anime Wanita 🌸)
VOICE_ALERT_STYLE=stasiun

# Bahasa suara Text-to-Speech (id = Bahasa Indonesia, en = Bahasa Inggris)
VOICE_ALERT_LANG=id

# Suara saat perangkat BARU terdeteksi (true/false)
VOICE_ALERT_ON_NEW_DEVICE=true

# Suara saat perangkat terhubung kembali (true/false)
VOICE_ALERT_ON_RECONNECT=true

# Suara saat perangkat terputus (true/false)
VOICE_ALERT_ON_DISCONNECT=true

# ──────────────────────────────────────────
# Dashboard Configuration
# ──────────────────────────────────────────
# Port untuk web dashboard
DASHBOARD_PORT=3000

# Aktifkan dashboard (true/false)
DASHBOARD_ENABLED=true

# ──────────────────────────────────────────
# Advanced
# ──────────────────────────────────────────
# Deep scan dengan nmap (lebih lambat tapi lebih detail)
DEEP_SCAN_ENABLED=true

# Interval deep scan dalam menit (default: 5)
DEEP_SCAN_INTERVAL=5

# Log level: debug, info, warn, error
LOG_LEVEL=info
